#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
LOG_FILE="$HOME/Library/Logs/RosterMate.log"
mkdir -p "$(dirname "$LOG_FILE")"

if [ ! -x "$APP_ROOT/.venv/bin/python3" ]; then
  osascript -e 'display notification "Første installation kan tage et par minutter" with title "RosterMate installerer"' >/dev/null 2>&1 || true
  if ! (
    cd "$APP_ROOT"
    ./install.command >>"$LOG_FILE" 2>&1
  ); then
    osascript -e 'display alert "RosterMate kunne ikke installeres" message "Kontrollér internetforbindelsen, og se loggen i Bibliotek/Logs/RosterMate.log." as critical' >/dev/null 2>&1 || true
    exit 1
  fi
fi

EXPECTED_VERSION="$(cd "$APP_ROOT" && .venv/bin/python3 -c 'import app; print(app.APP_VERSION)')"
PORT="$(cd "$APP_ROOT" && .venv/bin/python3 port_config.py configured)"
current_health="$(curl -fsS "http://127.0.0.1:$PORT/health" 2>/dev/null || true)"

if printf '%s' "$current_health" | grep -q "\"version\":\"$EXPECTED_VERSION\""; then
  server_pid="$(lsof -ti tcp:"$PORT" 2>/dev/null | head -1 || true)"
  open "http://localhost:$PORT/wizard/" >/dev/null 2>&1 || true
  exec "$APP_ROOT/.venv/bin/python3" "$APP_ROOT/tray.py" --server-pid "${server_pid:-0}"
fi

if printf '%s' "$current_health" | grep -q '"status":"ok"' && command -v lsof >/dev/null 2>&1; then
  pids="$(lsof -ti tcp:"$PORT" 2>/dev/null || true)"
  if [ -n "$pids" ]; then
    kill $pids 2>/dev/null || true
  fi
fi

PORT="$(cd "$APP_ROOT" && .venv/bin/python3 port_config.py ensure)"
export ROSTERMATE_PORT="$PORT"

(
  cd "$APP_ROOT"
  ./run.command >"$LOG_FILE" 2>&1
) &
server_pid=$!

for _ in $(seq 1 60); do
  health="$(curl -fsS "http://127.0.0.1:$PORT/health" 2>/dev/null || true)"
  if printf '%s' "$health" | grep -q "\"version\":\"$EXPECTED_VERSION\""; then
    open "http://localhost:$PORT/wizard/" >/dev/null 2>&1 || true
    wait "$server_pid" 2>/dev/null || true
    exit 0
  fi
  sleep 1
done

osascript -e "display alert \"RosterMate kunne ikke starte\" message \"Den korrekte version svarede ikke på port $PORT. Se loggen i Bibliotek/Logs/RosterMate.log.\" as critical" >/dev/null 2>&1 || true
exit 1
