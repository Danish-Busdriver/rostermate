  <organization>dk.pullen.rostermate</organization>
  <domains enable_localSystem="true"/>
  <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
  <welcome file="welcome.html" mime-type="text/html"/>
  <conclusion file="conclusion.html" mime-type="text/html"/>
  <pkg-ref id="dk.pullen.rostermate.pkg"/>
  <choices-outline>
    <line choice="rostermate"/>
  </choices-outline>
  <choice id="rostermate" visible="false">
    <pkg-ref id="dk.pullen.rostermate.pkg"/>
  </choice>
  <pkg-ref id="dk.pullen.rostermate.pkg" version="1.7.0" onConclusion="none">RosterMate-component.pkg</pkg-ref>
</installer-gui-script>
